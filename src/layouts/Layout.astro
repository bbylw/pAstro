---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "WebNav Hub",
  description = "WebNav Hub - 个人常用网站导航集合",
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/@fortawesome/fontawesome-free@7.2.0/css/all.min.css"
    />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>